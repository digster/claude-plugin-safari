{
  "manifest_version": 3,
  "name": "Claude Assistant",
  "version": "1.0.0",
  "description": "Run Claude CLI on the current page URL with a configurable prefix prompt",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "options_ui": {
    "page": "settings/settings.html"
  },
  "permissions": [
    "storage",
    "tabs",
    "nativeMessaging",
    "activeTab"
  ]
}
